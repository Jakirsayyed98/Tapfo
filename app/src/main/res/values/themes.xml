    <style name="Theme_Tapfo" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/purple_500</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->

        <item name="fontFamily">@font/kollektif_bold</item>
        <item name="android:fontFamily">@font/kollektif_bold</item>
        <item name="android:textViewStyle">@style/TextViewNormal</item>

        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>


        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowDisablePreview">true</item>
<!--        <item name="android:windowBackground">@android:color/transparent</item>-->
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">true</item>
<!--         <item name="android:windowLightStatusBar" tools:ignore="NewApi">true</item>-->
    </style>

    <style name="Theme_Tapfo_BlackStatusBar" parent="Theme_Tapfo">
        <item name="android:windowLightStatusBar" tools:ignore="NewApi">false</item>
    </style>

    <style name="TextViewBold" parent="android:Widget.TextView">
        <item name="fontFamily">@font/kollektif_bold</item>
        <item name="android:fontFamily">@font/kollektif_bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextViewBold1" parent="android:Widget.TextView">
        <item name="fontFamily">@font/kollektif_bold</item>
        <item name="android:fontFamily">@font/kollektif_bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextViewNormal" parent="android:Widget.TextView">
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:fontFamily">@font/kollektif_bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextViewSemiBold" parent="android:Widget.TextView">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/kollektif_bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Theme_Tapfo.NoActionBar">
        <!--<item name="statusBarBackground">@color/transparent</item>-->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">false</item>
    </style>

    <style name="AppBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppModalStyle</item>
    </style>

    <style name="AppModalStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/gamewebviewdialog</item>
    </style>
