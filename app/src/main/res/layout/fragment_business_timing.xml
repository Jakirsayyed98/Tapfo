<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".ui.localbizzUI.BusinessFlow.BusinessTimingFragment">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_white2"
        android:visibility="visible" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp10"
                android:orientation="vertical"
                android:paddingLeft="@dimen/dp15"
                android:layout_marginBottom="@dimen/dp20"
                android:paddingRight="@dimen/dp15">


                <!-- About Hours-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp10"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/dp10">

                    <androidx.cardview.widget.CardView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        app:cardBackgroundColor="@color/Minicash"
                        app:cardCornerRadius="@dimen/dp50">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/Minicash"
                            android:padding="5dp"
                            android:src="@drawable/info"
                            app:tint="@color/white" />

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginLeft="@dimen/dp20"
                        android:layout_weight="1"
                        android:text="Business Hours"
                        android:textSize="@dimen/sp20"
                        app:fontFamily="@font/inter_bold" />


                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="@dimen/dp60"
                    android:layout_weight="1"
                    android:text="Please enter or update your business operation hours."
                    android:textSize="13sp"
                    app:fontFamily="@font/roboto_light" />

                <!--   Everday  Business Hours -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp10"
                    android:orientation="vertical">

<!--                    Everday-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <CheckBox
                            android:id="@+id/everday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Always Open"
                            app:fontFamily="@font/roboto_condensed_bold"
                            android:textSize="18sp"/>


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginLeft="@dimen/dp30"
                            android:layout_weight="1"
                            android:layout_marginBottom="@dimen/dp5"
                            android:text="eg: Petrol pump, hospital, Pharmacy or more"
                            android:textSize="12sp"
                            app:fontFamily="@font/roboto_light" />



                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp10"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/grey_light"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="@dimen/dp10"
                        android:layout_weight="1"/>


                </LinearLayout>

<!--                monday-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp10"
                    android:orientation="vertical">

                    <!--                    Everday-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <CheckBox
                            android:id="@+id/monday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Monday"
                            app:fontFamily="@font/roboto_condensed_bold"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:id="@+id/mondaytime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/dp10"
                                android:layout_weight="1"
                                android:background="@drawable/button_boarder_2">
                                <TextView
                                    android:id="@+id/mondaystart"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:text="Closed"
                                    android:gravity="center"
                                    android:textSize="14sp"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/dp10"
                                android:layout_weight="1"
                                android:background="@drawable/button_boarder_2">
                                <TextView
                                    android:id="@+id/mondayend"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="5dp"
                                    android:text="Closed"
                                    android:gravity="center"
                                    android:textSize="14sp"/>
                            </LinearLayout>


                        </LinearLayout>

                    </LinearLayout>


                </LinearLayout>

<!--                Tuesday-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp10"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <CheckBox
                            android:id="@+id/Tuesday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tuesday"
                            app:fontFamily="@font/roboto_condensed_bold"
                            android:textSize="18sp"/>

                        <LinearLayout
