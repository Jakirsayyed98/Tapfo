                                    android:layout_height="wrap_content"
                                    android:text="Closed"
                                    android:layout_margin="5dp"
                                    android:gravity="center"
                                    android:textSize="14sp"/>
                            </LinearLayout>


                        </LinearLayout>

                    </LinearLayout>


                </LinearLayout>

                <!--                Wednesday-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
