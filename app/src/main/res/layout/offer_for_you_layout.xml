    <LinearLayout
        android:layout_width="@dimen/dp160"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:layout_margin="@dimen/dp3">
    <androidx.cardview.widget.CardView
        android:layout_width="@dimen/dp160"
        android:layout_height="160dp"
        app:cardCornerRadius="10dp"
        android:elevation="@dimen/dp2">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="@dimen/dp100">
                <ImageView
                    android:id="@+id/iv_partner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/dp2"/>
            </androidx.cardview.widget.CardView>

            <ImageView
                android:id="@+id/iv_cardpartner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/paytm_dark_blue" />
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/cardshades" />

            <TextView
                android:id="@+id/cashbackTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginLeft="@dimen/dp8"
                android:layout_marginRight="@dimen/dp8"
                android:layout_marginBottom="@dimen/dp8"
                android:maxLines="2"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:fontFamily="@font/inter_bold" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/nameTv"
            style="@style/TextViewSemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:layout_marginTop="@dimen/dp5"
            android:textSize="@dimen/sp16"
            android:paddingLeft="10dp"
            app:fontFamily="@font/inter_bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/discription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/grey_font"
            android:layout_marginTop="@dimen/dp5"
            android:textSize="@dimen/sp12"
            android:paddingLeft="10dp"
            android:visibility="gone"
            app:fontFamily="@font/inter_regular"
            android:maxLines="1" />
    </LinearLayout>
</LinearLayout>