<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="@dimen/dp5"
    tools:context=".ui.tcashback_detail_Activity">

    <ImageView
        android:id="@+id/back"
        android:layout_width="30dp"
        android:layout_height="@dimen/dp30"
        android:layout_margin="@dimen/dp20"
        android:src="@drawable/new_back_btn" />


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp10"
                android:layout_marginTop="5dp"
                android:layout_marginRight="@dimen/dp10"
                app:cardElevation="3dp"
                app:cardCornerRadius="@dimen/dp15">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp20"
                            android:layout_marginBottom="@dimen/dp20"
                            android:layout_weight="1"
                            android:layout_marginLeft="@dimen/dp20"
                            android:layout_marginRight="@dimen/dp10">

                            <androidx.cardview.widget.CardView
                                android:layout_width="45dp"
                                android:layout_height="45dp"
                                android:layout_margin="@dimen/dp2"
                                app:cardCornerRadius="@dimen/dp100">

                                <ImageView
                                    android:id="@+id/merchantIv"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_margin="@dimen/dp2" />
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:id="@+id/merchantNameTv"
                                android:layout_width="@dimen/dp150"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="@dimen/dp10"
                                android:text="Make my Trip (Domehbsdfyaseystic "
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:textSize="20sp"
                                app:fontFamily="@font/inter_bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp20"
                            android:layout_marginRight="20dp"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Order amount"
                                android:textColor="@color/grey_dark"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/orderAmountTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹150.00"
                                android:textColor="@color/black"
                                android:textSize="17sp"
                                app:fontFamily="@font/inter_bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp20"
                        android:layout_marginRight="@dimen/dp20"
                        android:layout_marginBottom="@dimen/dp20"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/transactionId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ID: 7879889078"
                            android:textColor="@color/grey_dark"
                            android:ellipsize="end"
                            android:textSize="@dimen/sp14" />

                        <TextView
                            android:id="@+id/dateTv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="27 Dec 22 9:00 AM "
                            android:textColor="@color/grey_dark"
                            android:textSize="@dimen/sp12" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp20"
                        android:layout_marginRight="@dimen/dp20"
                        android:layout_marginBottom="5dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/cashbackPercentage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="52.7% Cashback"
                            android:textAllCaps="true"
                            android:textColor="#3B077D"
                            android:textSize="17sp"
                            app:fontFamily="@font/inter_bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:paddingLeft="@dimen/dp20"
                            android:gravity="end|center"
                            android:text="After cashback "
                            android:textColor="@color/grey_dark"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp20"
                        android:layout_marginRight="@dimen/dp20"
                        android:layout_marginBottom="@dimen/dp20"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/cashbackAmountTv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹74"
                            android:textColor="@color/grey_dark"
                            android:textStyle="bold"
                            android:textSize="@dimen/sp12" />

                        <TextView
                            android:id="@+id/aftercashback"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="₹100.00"
                            android:textColor="@color/green_dark"
                            android:textSize="15sp"
                            app:fontFamily="@font/inter_bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp20"
                android:layout_marginTop="@dimen/dp20"
                android:layout_marginRight="@dimen/dp20"
                android:layout_marginBottom="@dimen/dp15"
                android:text="Cashback status"
                android:textSize="12sp"
                app:fontFamily="@font/inter_bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp10"
                android:layout_marginRight="@dimen/dp10"
                app:cardElevation="3dp"
                app:cardCornerRadius="@dimen/dp10">

                <RelativeLayout
                    android:id="@+id/Visibility_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dp10">

                    <View
                        android:layout_width="@dimen/dp1"
                        android:layout_height="15dp"
                        android:layout_alignTop="@+id/liNotice"
                        android:layout_alignBottom="@+id/liNotice"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="@dimen/dp10"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/sp_vertical_line"
                        android:backgroundTint="#2AAF0C" />

                    <LinearLayout
                        android:id="@+id/liNotice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/dp10">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="@dimen/dp20"
                                android:layout_height="@dimen/dp20"
                                android:layout_gravity="center"
                                android:layout_marginRight="@dimen/dp5"
                                android:src="@drawable/verifiedok" />

                            <TextView
                                android:id="@+id/activeTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginLeft="@dimen/dp5"
                                android:text="Cashback tracked"
                                android:textColor="#6E6868"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:fontFamily="@font/inter_regular" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp20">

                            <ImageView
                                android:layout_width="@dimen/dp20"
                                android:layout_height="@dimen/dp20"
                                android:layout_gravity="center"
                                android:layout_marginRight="@dimen/dp5"
                                android:src="@drawable/verifiedok" />

                            <TextView
                                android:id="@+id/redirectline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginLeft="@dimen/dp5"
                                android:fontFamily="@font/inter_regular"
                                android:text="@string/cashback_recieved_from"
                                android:textColor="#6E6868"
                                android:textSize="12sp"
                                app:fontFamily="@font/inter_regular" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp20">

                            <ImageView
                                android:layout_width="@dimen/dp20"
                                android:layout_height="@dimen/dp20"
                                android:layout_gravity="center"
                                android:layout_marginRight="@dimen/dp5"
                                android:src="@drawable/verifiedok" />


                            <TextView
                                android:id="@+id/redirectline1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginLeft="@dimen/dp5"
                                android:fontFamily="@font/inter_regular"
                                android:text="@string/cashbackhold2"
                                android:textColor="#6E6868"
                                android:textSize="12sp"
                                app:fontFamily="@font/inter_regular" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp20">

                            <com.airbnb.lottie.LottieAnimationView
                                android:id="@+id/verifedConformation"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                app:lottie_autoPlay="true"
                                app:lottie_loop="true"
                                app:lottie_rawRes="@raw/verification_progress" />

                            <TextView
                                android:id="@+id/statusTextTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginLeft="@dimen/dp5"
                                android:fontFamily="@font/inter_regular"
                                android:text="@string/cashback_pending_from_"
                                android:textColor="#6E6868"
                                android:textSize="12sp"
                                app:fontFamily="@font/inter_regular" />
                        </LinearLayout>


                    </LinearLayout>

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp20"
                android:layout_marginTop="@dimen/dp20"
                android:layout_marginRight="@dimen/dp20"
                android:layout_marginBottom="@dimen/dp15"
                android:text="Cashback details"
                android:textSize="12sp"
                app:fontFamily="@font/inter_bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp10"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginRight="@dimen/dp10"
                app:cardElevation="3dp"
                app:cardCornerRadius="@dimen/dp10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp20"
                        android:orientation="horizontal">


                        <TextView
                            android:id="@+id/status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/dp15"
                            android:text="@string/your_cashback_is_pending_from_swiggy"
                            android:textColor="@color/orange" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/dp15"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/cashbackAmountTv2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_74_cashback"
                                android:textColor="@color/black"
                                android:textSize="20sp" />

                            <TextView
                                android:id="@+id/cashbackPercentage2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="52.7% cashback "
                                android:textColor="@color/purple_200"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/validation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:layout_gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/valid"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Validation period"
                                android:textColor="@color/purple_200"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/validationPeriodTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="29 July 2022"
                                android:textColor="@color/black"
                                android:textSize="12sp" />


                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp20"
                android:layout_marginTop="@dimen/dp20"
                android:layout_marginRight="@dimen/dp20"
                android:layout_marginBottom="@dimen/dp15"
                android:text="Terms &amp; policy"
                android:textSize="12sp"
                app:fontFamily="@font/inter_bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dp10"
                    android:layout_weight="1"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="@dimen/dp10">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dp10">

                        <ImageView
                            android:layout_width="@dimen/dp30"
                            android:layout_height="@dimen/dp30"
                            android:src="@drawable/watch_icon"
                            />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cashback takes 45- 60 days for validation"
                            android:layout_marginTop="@dimen/dp10"
                            android:layout_marginBottom="10dp"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dp10"
                    android:layout_weight="1"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="@dimen/dp10">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dp10">

                        <ImageView
                            android:layout_width="@dimen/dp30"
                            android:layout_height="@dimen/dp30"
                            android:src="@drawable/cb_tcash_icon" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cashback will be rejected on return, refund &amp; cancelled status."
                            android:layout_marginTop="@dimen/dp10"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dp10"
                    android:layout_weight="1"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="@dimen/dp10">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dp10">

                        <ImageView
                            android:layout_width="@dimen/dp30"
                            android:layout_height="@dimen/dp30"
                            android:src="@drawable/cb_tcash_icon_2" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cashback amount is non-transferable  as per new RBI guidlines"
                            android:layout_marginTop="@dimen/dp10"
                            android:layout_marginBottom="@dimen/dp10"
                            android:textSize="9sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp10"
                app:cardElevation="@dimen/dp10"
                app:cardCornerRadius="@dimen/dp10">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dp20"
                    android:text="@string/tip_make_sure_you_will_not_return"
                    android:textColor="@color/grey_dark"
                    android:textSize="12sp" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp10"
                android:layout_marginTop="@dimen/dp5"
                android:layout_marginRight="@dimen/dp10"
                app:cardElevation="@dimen/dp10"
                android:layout_marginBottom="@dimen/dp20"
                android:elevation="@dimen/dp10"
                app:cardCornerRadius="@dimen/dp10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/dp20"
                        android:text="@string/if_your_cancel_return_or_refund_under"
                        android:textColor="@color/grey_dark"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp20"
                        android:layout_marginRight="@dimen/dp20"
                        android:layout_marginBottom="@dimen/dp10"
                        android:text="Cashback is applicable on validated order. ( non - returnred/refunded/ cancelled )"
                        android:textColor="@color/grey_dark"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>