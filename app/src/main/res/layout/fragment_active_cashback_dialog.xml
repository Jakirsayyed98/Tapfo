<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activecashback.ActiveCashbackDialogFragment">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/cashbackscreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/screen"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-20dp"
                            android:layout_marginBottom="@dimen/dp20"
                            app:cardBackgroundColor="@color/grey_v_light"
                            app:cardCornerRadius="@dimen/dp20">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/dp20"
                                android:layout_marginTop="100dp"
                                android:layout_marginRight="@dimen/dp20"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_vertical"
                                        android:layout_marginLeft="@dimen/dp5"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/storename"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:text="Swiggy "
                                            android:textSize="26sp"
                                            app:fontFamily="@font/roboto_condensed_bold" />

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:text="Miniearn "
                                            android:textSize="14sp"
                                            app:fontFamily="@font/roboto_light" />


                                    </LinearLayout>

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="@dimen/dp50"
                                        android:layout_height="@dimen/dp50"
                                        android:layout_margin="@dimen/dp3"
                                        app:cardElevation="3dp"
                                        app:cardCornerRadius="@dimen/dp100">

                                        <ImageView
                                            android:id="@+id/productIv"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:src="@drawable/intro_1"
                                            android:layout_margin="@dimen/dp2"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="@dimen/dp15">

                                    <androidx.cardview.widget.CardView
                                        android:id="@+id/card1"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="@dimen/dp2"
                                        android:layout_marginTop="@dimen/dp15"
                                        android:layout_marginRight="@dimen/dp2"
                                        app:cardBackgroundColor="@color/white"
                                        app:cardCornerRadius="@dimen/dp10">

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/dp10"
                                            android:orientation="vertical"
                                            android:paddingLeft="@dimen/dp10"
                                            android:paddingRight="@dimen/dp10">

                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="@dimen/dp10"
                                                android:orientation="horizontal">

                                                <ImageView
                                                    android:id="@+id/logo"
                                                    android:layout_width="match_parent"
                                                    android:layout_height="50dp"
                                                    android:paddingTop="@dimen/dp10"
                                                    android:paddingRight="@dimen/dp10"
                                                    android:layout_weight="1" />

                                                <TextView
                                                    android:id="@+id/cashback"
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_gravity="center_vertical"
                                                    android:layout_weight="1"
                                                    android:gravity="end"
                                                    android:text="@string/upto_9_cashback"
                                                    android:textSize="18sp"
                                                    app:fontFamily="@font/roboto_condensed_bold" />
                                            </LinearLayout>

                                            <TextView
                                                android:id="@+id/discription"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="@dimen/dp15"
                                                android:ellipsize="end"
                                                android:maxLines="2"
                                                android:text="Swiggy is an Indian online food ordering and delivery platform. Founded in July 2014, Swiggy is based ..."
                                                android:textSize="@dimen/sp12"
                                                app:fontFamily="@font/roboto_light" />

                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="@dimen/dp15"
                                                android:layout_marginBottom="@dimen/dp50"
                                                android:orientation="horizontal">

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_weight="1"
                                                    android:gravity="center"
                                                    android:orientation="vertical">

                                                    <TextView
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:gravity="center"
                                                        android:text="Tcoin Credit"
                                                        android:textSize="15sp"
                                                        app:fontFamily="@font/roboto_condensed_bold" />

                                                    <TextView
                                                        android:id="@+id/report"
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:gravity="center"
                                                        android:text="Instant"
                                                        android:textColor="@color/grey_dark"
                                                        android:textSize="13sp"
                                                        app:fontFamily="@font/inter_regular" />

                                                </LinearLayout>

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_weight="1"
                                                    android:gravity="center"
                                                    android:orientation="vertical">

                                                    <TextView
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:gravity="center"
                                                        android:text="Validation"
                                                        android:textSize="15sp"
                                                        app:fontFamily="@font/roboto_condensed_bold" />

                                                    <TextView
                                                        android:id="@id/validation"
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:gravity="center"
                                                        android:text="45-60 Days"
                                                        android:textColor="@color/grey_dark"
                                                        android:textSize="13sp"
                                                        app:fontFamily="@font/inter_regular" />

                                                </LinearLayout>

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_weight="1"
                                                    android:gravity="center"
                                                    android:orientation="vertical">

                                                    <TextView
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:gravity="center"
                                                        android:text="Rewards"
                                                        android:textSize="15sp"
                                                        app:fontFamily="@font/roboto_condensed_bold" />

                                                    <TextView
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:gravity="center"
                                                        android:text="TCoins"
                                                        android:textColor="@color/grey_dark"
                                                        android:textSize="13sp"
                                                        app:fontFamily="@font/inter_regular" />

                                                </LinearLayout>

                                            </LinearLayout>

                                        </LinearLayout>
                                    </androidx.cardview.widget.CardView>

                                    <androidx.cardview.widget.CardView
                                        android:id="@+id/alltransaction"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_below="@+id/card1"
                                        android:layout_marginLeft="@dimen/dp15"
                                        android:layout_marginTop="-40dp"
                                        android:layout_marginRight="@dimen/dp15"
                                        android:layout_marginBottom="@dimen/dp5"
                                        app:cardBackgroundColor="@color/white"
                                        app:cardCornerRadius="@dimen/dp10"
                                        app:cardElevation="@dimen/dp5">

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/dp15"
                                            android:orientation="vertical"
                                            android:paddingLeft="@dimen/dp10"
                                            android:paddingRight="@dimen/dp10">

                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:orientation="horizontal">

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_weight="1"
                                                    android:orientation="vertical">

                                                    <TextView
                                                        android:id="@+id/nameTv3"
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:text="Swiggy"
                                                        android:textColor="@color/black"
                                                        app:fontFamily="@font/kollektif_bold" />


                                                    <TextView
                                                        android:layout_width="match_parent"
                                                        android:layout_height="wrap_content"
                                                        android:text="Rewards"
                                                        android:textColor="@color/black"
                                                        android:textSize="10sp"
                                                        app:fontFamily="@font/roboto_light" />


                                                </LinearLayout>

                                            </LinearLayout>

                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="@dimen/dp10"
                                                android:orientation="horizontal">

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_gravity="center_vertical"
                                                    android:layout_weight="1"
                                                    android:orientation="horizontal">


                                                    <LinearLayout
                                                        android:layout_width="wrap_content"
                                                        android:layout_height="wrap_content"
                                                        android:orientation="vertical">

                                                        <TextView
                                                            android:layout_width="wrap_content"
                                                            android:layout_height="wrap_content"
                                                            android:layout_marginTop="@dimen/dp5"
                                                            android:layout_weight="1"
                                                            android:drawableEnd="@drawable/small_info"
                                                            android:text="Credited "
                                                            android:textColor="@color/grey_dark"
                                                            android:textSize="10sp" />


                                                        <TextView
                                                            android:id="@+id/verified_amount"
                                                            android:layout_width="match_parent"
                                                            android:layout_height="wrap_content"
                                                            android:layout_marginTop="-5dp"
                                                            android:layout_weight="1"
                                                            android:text="20202"
                                                            android:textColor="@color/new_green2"
                                                            android:textSize="22sp"
                                                            app:fontFamily="@font/baloo" />


                                                    </LinearLayout>

                                                </LinearLayout>

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:layout_gravity="center_vertical"
                                                    android:layout_weight="1"
                                                    android:gravity="end"
                                                    android:orientation="horizontal">

                                                    <LinearLayout
                                                        android:layout_width="wrap_content"
                                                        android:layout_height="wrap_content"
                                                        android:orientation="vertical">

                                                        <TextView
                                                            android:layout_width="match_parent"
                                                            android:layout_height="wrap_content"
                                                            android:layout_marginTop="@dimen/dp5"
                                                            android:layout_weight="1"
                                                            android:drawableEnd="@drawable/small_info"
                                                            android:text="Pending Credit "
                                                            android:textColor="@color/grey_dark"
                                                            android:textSize="10sp" />

                                                        <LinearLayout
                                                            android:layout_width="match_parent"
                                                            android:layout_height="wrap_content"
                                                            android:orientation="horizontal">

                                                            <ImageView
                                                                android:layout_width="30dp"
                                                                android:layout_height="30dp"
                                                                android:padding="@dimen/dp5"
                                                                android:src="@drawable/tcoin_icon"
                                                                android:textColor="@color/black"
                                                                app:fontFamily="@font/kollektif_bold" />


                                                            <TextView
                                                                android:id="@+id/pendingcashback"
                                                                android:layout_width="match_parent"
                                                                android:layout_height="wrap_content"
                                                                android:layout_weight="1"
                                                                android:text="20202"
                                                                android:textColor="@color/new_green2"
                                                                android:textSize="22sp"
                                                                app:fontFamily="@font/baloo" />

                                                        </LinearLayout>
                                                    </LinearLayout>

                                                </LinearLayout>

                                            </LinearLayout>

                                        </LinearLayout>
                                    </androidx.cardview.widget.CardView>

                                </RelativeLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/mainRe"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingTop="@dimen/dp20"
                                android:paddingBottom="14dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="@dimen/dp50"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:id="@+id/back_btn"
                                        android:layout_width="@dimen/dp40"
                                        android:layout_height="@dimen/dp40"
                                        android:layout_marginLeft="@dimen/dp10"
                                        android:layout_marginTop="@dimen/dp5"
                                        android:padding="5dp"
                                        android:layout_gravity="center_vertical"
                                        android:src="@drawable/new_back_btn"
                                        app:tint="@color/black" />

                                    <RelativeLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/dp5"
                                        android:gravity="end"
                                        android:layout_gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <LinearLayout
                                            android:id="@+id/cardfav"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_alignParentEnd="true"
                                            android:layout_marginEnd="10dp"
                                            android:layout_marginRight="@dimen/dp10"
                                            android:gravity="center_vertical">


                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_margin="@dimen/dp10"
                                                android:background="@color/transparent"
                                                android:orientation="horizontal">

                                                <ImageView
                                                    android:id="@+id/info"
                                                    android:layout_width="20dp"
                                                    android:layout_height="20dp"
                                                    android:layout_alignParentEnd="true"
                                                    android:src="@drawable/info"
                                                    app:tint="@color/black" />
                                            </LinearLayout>


                                        </LinearLayout>

                                    </RelativeLayout>
                                </LinearLayout>


                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!--Tcashdata-->


                    <TextView
                        android:id="@+id/terms_and_condition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp10"
                        android:gravity="center"
                        android:paddingLeft="@dimen/dp40"
                        android:paddingRight="@dimen/dp40"
                        android:layout_marginLeft="@dimen/dp15"
                        android:layout_marginRight="@dimen/dp15"
                        android:text="@string/by_proceeding_to"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:id="@+id/continueLi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="@dimen/dp10"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="@dimen/dp10"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/button_border_orange"
                        android:backgroundTint="@color/new_green2"
                        android:elevation="@dimen/dp5"
                        android:orientation="vertical"
                        android:padding="@dimen/dp15">

                        <TextView
                            android:id="@+id/nameTv2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Open Swiggy "
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp16"
                            app:fontFamily="@font/inter_bold" />

                        <TextView
                            android:id="@+id/cashback1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="to activate upto 5% cashback*"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:fontFamily="@font/roboto_light" />

                    </LinearLayout>



                </LinearLayout>
            </androidx.core.widget.NestedScrollView>


        </RelativeLayout>

    </RelativeLayout>

</RelativeLayout>