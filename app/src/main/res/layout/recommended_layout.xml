<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.cardview.widget.CardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp5"
        android:layout_gravity="center"
        app:cardCornerRadius="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dp5"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/dp100"
                android:layout_marginLeft="@dimen/dp20"
                android:layout_marginTop="@dimen/dp20">
                <ImageView
                    android:id="@+id/iv_partner"
                    android:layout_width="@dimen/dp50"
                    android:layout_height="@dimen/dp50"
                    android:layout_margin="@dimen/dp2"
                    android:src="@color/orange1"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:fontFamily="@font/inter_bold"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="@dimen/dp20"
                android:textColor="@color/white"
                android:maxLines="1"
                android:textSize="@dimen/sp16"
                android:text="MerName"/>

            <TextView
                android:id="@+id/cashback"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                app:fontFamily="@font/inter_bold"
                android:layout_marginTop="15dp"
                android:textColor="@color/white"
                android:layout_marginLeft="@dimen/dp20"
                android:textSize="25sp"
                android:text="Upto 9% Cashback"/>
            <TextView
                android:id="@+id/terms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp20"
                android:textSize="8sp"
                android:textColor="@color/white"
                android:layout_marginBottom="@dimen/dp10"
                android:layout_marginTop="10dp"
                android:text="on order* T&amp;C Apply"/>

            <TextView
                android:id="@+id/forUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="for new users only"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:paddingTop="@dimen/dp5"
                android:visibility="gone"
                android:paddingBottom="10dp"
                android:layout_marginBottom="@dimen/dp10"
                android:layout_marginTop="@dimen/dp10"
                android:paddingLeft="@dimen/dp20"
                android:background="@color/black"/>


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>