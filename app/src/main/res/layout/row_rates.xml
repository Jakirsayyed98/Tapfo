<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:weightSum="3"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/cashbackRatesTv"
        style="@style/TextViewSemiBold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="@dimen/dp10"
        android:layout_marginEnd="@dimen/dp10"
        android:layout_weight="2"
        android:gravity="center"
        android:textColor="@color/red"
        tools:text="7.90% / 1.32%" />

    <View
        android:layout_width="@dimen/dp1"
        android:layout_height="match_parent"
        android:background="@color/grey_tabs" />

    <TextView
        android:id="@+id/termsTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/dp5"
        android:layout_marginBottom="@dimen/dp5"
        android:layout_weight="1"
        android:paddingStart="@dimen/dp10"
        android:paddingEnd="@dimen/dp10"
        android:textColor="@color/black"
        tools:text="Grocery- Flipkart Supermart (Live in Delhi, Mumbai, Chennai, Hyderabad &amp; Bengaluru " />


</LinearLayout>