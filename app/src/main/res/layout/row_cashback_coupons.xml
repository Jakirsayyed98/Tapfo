<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp5"
    android:layout_marginBottom="@dimen/dp5">

    <TextView
        android:id="@+id/totalAmountTv"
        style="@style/TextViewBold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5000"
        android:textColor="@color/tab_unselected_text_color"
        android:textSize="@dimen/sp20" />

    <TextView
        android:id="@+id/cashbackPerTv"
        style="@style/TextViewNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/totalAmountTv"
        android:text="@string/_cashback"
        android:textColor="@color/purple_500"
        android:textSize="@dimen/sp12" />

    <TextView
        android:id="@+id/popularTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@+id/cashbackPerTv"
        android:background="@drawable/sp_white_corner_10"
        android:backgroundTint="#FF973D"
        android:paddingStart="@dimen/dp3"
        android:paddingTop="@dimen/dp2"
        android:paddingEnd="@dimen/dp3"
        android:paddingBottom="@dimen/dp2"
        android:text="@string/popular"
        android:textColor="@color/white"
        android:textSize="@dimen/sp12" />

    <TextView
        android:id="@+id/cashbackAmountTv"
        style="@style/TextViewBold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:text="80"
        android:textColor="@drawable/selector_coupon_cashback"
        android:textSize="@dimen/sp20" />

    <TextView
        android:id="@+id/cashbackTv2"
        style="@style/TextViewNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/cashbackAmountTv"
        android:layout_centerHorizontal="true"
        android:text="@string/cashback"
        android:textColor="@drawable/selector_coupon_cashback2" />

    <RadioButton
        android:id="@+id/radio"
        android:buttonTint="@color/green_light"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true" />

</RelativeLayout>