<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp120"
        android:layout_margin="@dimen/dp5"
        app:cardElevation="@dimen/dp5"
        app:cardCornerRadius="@dimen/dp10">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/popular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="5dp"
                android:paddingRight="15dp"
                android:gravity="center"
                android:background="@color/paytm_blue"
                android:textColor="@color/white"
                android:rotation="-30"
                android:textSize="8sp"
                android:text="@string/popular"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="@dimen/dp15">

                <LinearLayout
                    android:id="@+id/nameline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="@dimen/dp10"
                    android:layout_marginLeft="@dimen/dp10"
                    android:layout_toStartOf="@+id/cashback"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/icon"
                        android:layout_width="match_parent"
                        android:layout_height="27dp" />


                </LinearLayout>

                <TextView
                    android:id="@+id/cashback"
                    android:layout_width="@dimen/dp70"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_gravity="end"
                    android:layout_marginRight="@dimen/dp10"
                    android:gravity="end"
                    android:textColor="@color/grey_dark"
                    android:padding="@dimen/dp5"
                    android:text="Upto 20% Cashback"
                    android:textSize="11sp" />
            </RelativeLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/discription"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp15"
                    android:maxLines="2"
                    android:paddingLeft="@dimen/dp10"

                    android:paddingRight="@dimen/dp10"
                    android:text="order food from nearbuy resturant"
                    android:textColor="#AFAFAF"
                    android:textSize="10sp" />

                <ImageView
                    android:id="@+id/favbtn"
                    android:layout_width="@dimen/dp30"
                    android:layout_height="@dimen/dp30"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="@dimen/dp15"
                    android:layout_marginEnd="20dp"
                    android:layout_marginRight="@dimen/dp15"
                    android:src="@drawable/favicon2"
                    app:tint="@color/orange2" />
            </RelativeLayout>
        </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>