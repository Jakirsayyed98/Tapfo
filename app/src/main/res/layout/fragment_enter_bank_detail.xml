<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".ui.AllUpiPaymentProcess.SendMoneyFromUPI.BankTransfer.EnterBankDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/dp10">

            <ImageView
                android:id="@+id/backIv"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center_vertical"
                android:layout_margin="15dp"
                android:src="@drawable/new_back_btn" />

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp10"
                    android:padding="@dimen/dp5"
                    android:text="@string/send_money_to_000_bank_account"
                    android:textColor="@color/black"
                    android:textSize="@dimen/sp16"
                    app:fontFamily="@font/inter_bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="40dp"
                    android:layout_height="@dimen/dp40"
                    android:layout_alignParentEnd="true"
                    android:layout_marginRight="@dimen/dp30"
                    android:background="@drawable/circle"
                    app:cardCornerRadius="@dimen/dp50"
                    android:layout_gravity="end"
                    app:cardElevation="5dp">

                    <FrameLayout
                        android:id="@+id/image_frame"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerHorizontal="true"
                        android:layout_margin="2dp">

                        <TextView
                            android:id="@+id/profileName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/circle"
                            android:backgroundTint="@color/red"
                            android:gravity="center"
                            android:maxLength="1"
                            android:text="A"
                            android:textAllCaps="true"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/profileIv"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_account_circle" />

                    </FrameLayout>
                </androidx.cardview.widget.CardView>

            </RelativeLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/dp5">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp10"
                    android:layout_marginRight="@dimen/dp10"
                    android:layout_marginTop="@dimen/dp10"
                    android:layout_weight="1"
                    android:background="@color/grey_v_light"
                    android:hint="Enter Bank Account Number"
                    android:textColorHint="@color/grey_light"
                    app:boxCornerRadiusBottomEnd="@dimen/dp10"
                    app:boxCornerRadiusBottomStart="@dimen/dp10"
                    app:boxCornerRadiusTopEnd="@dimen/dp10"
                    app:boxCornerRadiusTopStart="@dimen/dp10"
                    app:boxStrokeColor="@color/orange"
                    app:hintTextColor="@color/orange">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/AccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cursorColor="@color/black" />

                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp10"
                    android:layout_marginRight="@dimen/dp10"
                    android:layout_marginTop="@dimen/dp10"
                    android:layout_weight="1"
                    android:background="@color/grey_v_light"
                    android:hint="Re-enter account number"
                    android:textColorHint="@color/grey_light"
                    app:boxCornerRadiusBottomEnd="@dimen/dp10"
                    app:boxCornerRadiusBottomStart="@dimen/dp10"
                    app:boxCornerRadiusTopEnd="@dimen/dp10"
                    app:boxCornerRadiusTopStart="@dimen/dp10"
                    app:boxStrokeColor="@color/orange"
                    app:hintTextColor="@color/orange">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/Re_bankAccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cursorColor="@color/black" />

                </com.google.android.material.textfield.TextInputLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:id="@+id/ifcsdetail_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp10"
                    android:layout_marginRight="@dimen/dp10"
                    android:layout_marginTop="@dimen/dp10"
                    android:layout_weight="1"
                    android:background="@color/grey_v_light"
                    android:hint="IFSC CODE "
                    android:textColorHint="@color/grey_light"
                    app:boxCornerRadiusBottomEnd="@dimen/dp10"
                    app:boxCornerRadiusBottomStart="@dimen/dp10"
                    app:boxCornerRadiusTopEnd="@dimen/dp10"
                    app:boxCornerRadiusTopStart="@dimen/dp10"
                    app:boxStrokeColor="@color/orange"
                    app:hintTextColor="@color/orange">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/IFSC_CODE"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:inputType="text"
                        android:maxLength="10"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cursorColor="@color/black" />



                </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/findIFSC_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find IFSC"
                        android:textColor="@color/paytm_blue"
                        android:gravity="center"
                        android:layout_alignParentEnd="true"
                        android:layout_margin="30dp"
                        android:layout_centerVertical="true"
                        android:textSize="12sp" />
                </RelativeLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp10"
                    android:layout_marginRight="@dimen/dp10"
                    android:layout_marginTop="@dimen/dp10"
                    android:layout_weight="1"
                    android:background="@color/grey_v_light"
                    android:hint="Select Branch"
                    android:textColorHint="@color/grey_light"
                    app:boxCornerRadiusBottomEnd="@dimen/dp10"
                    app:boxCornerRadiusBottomStart="@dimen/dp10"
                    app:boxCornerRadiusTopEnd="@dimen/dp10"
                    app:boxCornerRadiusTopStart="@dimen/dp10"
                    app:boxStrokeColor="@color/orange"
                    app:hintTextColor="@color/orange">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/branchName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLength="10"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cursorColor="@color/black" />

                </com.google.android.material.textfield.TextInputLayout>



                <ImageView
                    android:id="@+id/contact"
                    android:layout_width="@dimen/dp60"
                    android:layout_height="@dimen/dp50"
                    android:layout_gravity="center"
                    android:layout_marginRight="@dimen/dp10"
                    android:visibility="gone"
                    android:layout_weight="1"
                    android:src="@drawable/contactbook_icon" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/proceedBtn"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_alignParentBottom="true"
                android:layout_marginLeft="@dimen/dp20"
                android:layout_marginTop="@dimen/dp30"
                android:layout_marginRight="@dimen/dp20"
                android:layout_marginBottom="20dp"
                android:background="@drawable/upi_payment_btn"
                android:paddingStart="@dimen/dp20"
                android:paddingRight="@dimen/dp20"
                android:text="Confirm &amp; Proceed"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/sp18"
                android:textStyle="bold"
                app:fontFamily="@font/roboto_light" />

            <TextView
                android:id="@+id/hintForUPIID"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp10"
                android:padding="@dimen/dp5"
                android:gravity="center"
                android:text="This information will be securely saved per Tapfo Pay Terms of\nservice and Privacy Policy"
                android:textColor="@color/grey_dark"
                android:textSize="11sp" />

        </LinearLayout>


    </LinearLayout>


</LinearLayout>