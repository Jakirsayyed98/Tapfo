<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/dp10"
        android:layout_margin="@dimen/dp5">
        <LinearLayout
            android:id="@+id/card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/intro_shades"
            android:padding="@dimen/dp10">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/cashbackAmt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp10"
                    android:layout_marginTop="@dimen/dp10"
                    android:layout_marginEnd="@dimen/dp10"
                    android:layout_marginBottom="@dimen/dp10"
                    android:text="@string/congrates_you_received"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:fontFamily="@font/kollektif_bold" />


                    <ImageView
                        android:id="@+id/image_icon"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                       android:layout_margin="@dimen/dp10"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"/>

            </RelativeLayout>

            <TextView
                android:id="@+id/refrenceIdTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reference ID: 1025e409d61ac7d534f82ebd45e875"
                android:textColor="@color/white"
                android:maxLength="35"
                android:textSize="@dimen/sp12"/>
            <TextView
                android:id="@+id/view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View details >"
                android:textColor="@color/white"
                android:layout_marginTop="@dimen/dp20"
                android:textSize="@dimen/sp12"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>