<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:layout_marginRight="@dimen/dp5"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/iv_partner"
        android:layout_width="@dimen/item_grid_image_height"
        android:layout_height="@dimen/item_grid_image_height"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/dp10"
        tools:src="@drawable/intro_1" />
<!--android:backgroundTint="@color/orange"-->
    <TextView
        android:id="@+id/rupee"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/iv_partner"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="-20dp"
        android:background="@drawable/button"
        android:backgroundTint="@color/orange"
        android:gravity="center"
        android:visibility="gone"
        android:paddingLeft="@dimen/dp5"
        android:paddingRight="@dimen/dp5"
        android:layout_alignParentTop="true"
        android:text="Cashback"
        android:textColor="@color/white"
        android:textSize="10dp" />

    <TextView
        android:id="@+id/nameTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/iv_partner"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/black"
        android:textSize="11sp"
        tools:text="More" />

    <TextView
        android:id="@+id/nameTv1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/iv_partner"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/black"
        android:textSize="@dimen/sp12"
        tools:text="Less" />

</RelativeLayout>