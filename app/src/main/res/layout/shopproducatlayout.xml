<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/producat"
        android:layout_width="190dp"
        android:layout_height="250dp"
        android:layout_margin="@dimen/dp10"
        android:elevation="@dimen/dp2"
        app:cardCornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">


            <androidx.cardview.widget.CardView
                android:id="@+id/cardView3"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_margin="@dimen/dp10"
                app:cardCornerRadius="@dimen/dp100"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/intro_1" />
            </androidx.cardview.widget.CardView>


            <ImageView
                android:id="@+id/iv_partner"
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:paddingLeft="@dimen/dp30"
                android:paddingRight="@dimen/dp30"
                android:paddingTop="@dimen/dp30"
                android:paddingBottom="@dimen/dp20"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:src="@drawable/intro_1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@+id/iv_partner"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/nameTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Real Narzo X7..."
                    android:paddingLeft="@dimen/dp10"
                    android:paddingRight="@dimen/dp10"
                    android:textSize="14sp"
                    app:fontFamily="@font/inter_bold" />

                <TextView
                    android:id="@+id/cashbackTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="1"
                    android:visibility="gone"
                    android:text="Real Narzo X7..."
                    android:textSize="20sp"
                    app:fontFamily="@font/inter_bold" />

                <TextView
                    android:id="@+id/deals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:paddingLeft="@dimen/dp15"
                    android:gravity="center"
                    android:textSize="9sp"
                    android:layout_marginTop="@dimen/dp5"
                    android:textColor="@color/green_dark"
                    android:fontFamily="@font/inter_regular"
                    android:paddingRight="@dimen/dp15"/>

            </LinearLayout>





        </RelativeLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>


</LinearLayout>