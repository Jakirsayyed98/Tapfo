<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">


    <androidx.cardview.widget.CardView
        android:layout_width="150dp"
        android:layout_height="170dp"
        android:layout_margin="@dimen/dp3"
        android:backgroundTint="#4D8C52FF"
        app:cardCornerRadius="@dimen/dp10"
        app:cardElevation="-5dp"
        android:elevation="@dimen/dp2">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/icon_card"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/dp20"
                app:cardCornerRadius="@dimen/dp100">

                <ImageView
                    android:id="@+id/icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </androidx.cardview.widget.CardView>


            <TextView
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/icon_card"
                android:layout_marginTop="@dimen/dp15"
                android:gravity="center_horizontal"
                android:text="Shop on Myntra"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/line"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp1"
                android:layout_below="@+id/name"
                android:layout_marginTop="@dimen/dp10"
                android:background="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/line"
                android:background="#668C52FF"
                android:layout_centerHorizontal="true">

                <TextView
                    android:id="@+id/cashback"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Get upto 9%\nCashback"
                    android:gravity="center"
                    android:textSize="10sp" />
            </LinearLayout>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>


</LinearLayout>