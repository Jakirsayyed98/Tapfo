<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.localbizzUI.BusinessProfileFlow.BusinessProfilePageFragment">
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_white2"
        android:visibility="visible" />

    <androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dp15">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/dp10"
        android:orientation="vertical">


    <LinearLayout
        android:id="@+id/addnewbusiness"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/button_boarder_2"
        android:layout_marginLeft="@dimen/dp20"
        android:layout_marginRight="@dimen/dp20"
        android:layout_marginTop="@dimen/dp15"
        android:orientation="horizontal">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Add New Business"
            android:gravity="center"
            android:layout_margin="@dimen/dp10"
            android:textColor="@color/new_green2"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/allprofile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp15"/>

<!--        help and support-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/button_boarder_2"
        android:layout_marginLeft="@dimen/dp20"
        android:layout_marginRight="@dimen/dp20"
        android:visibility="gone"
        android:layout_marginTop="@dimen/dp15"
        android:orientation="vertical">
        <TextView
            android:id="@+id/help_and_support"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Help &amp; Support"
            android:layout_margin="@dimen/dp10"
            app:fontFamily="@font/inter_bold"
            android:paddingLeft="@dimen/dp10"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/faqs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FAQs"
            android:layout_margin="@dimen/dp10"
            app:fontFamily="@font/inter_bold"
            android:paddingLeft="@dimen/dp10"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/termsandcondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Terms &amp; Policy"
            android:layout_margin="@dimen/dp10"
            app:fontFamily="@font/inter_bold"
            android:paddingLeft="@dimen/dp10"
            android:textColor="@color/black"/>

    </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
</LinearLayout>