<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/imageIv"
        android:layout_width="@dimen/item_grid_image_height"
        android:layout_height="@dimen/item_grid_image_height"
        android:layout_marginEnd="@dimen/dp10"
        android:contentDescription="@string/merchant"
        tools:src="@drawable/sp_black_corner_10" />

    <TextView
        android:id="@+id/headingTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/imageIv"
        tools:text="Bombay Shaving Company"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offerTv"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp30"
        android:layout_below="@+id/headingTv"
        android:layout_marginTop="@dimen/dp10"
        android:layout_toEndOf="@+id/imageIv"
        android:background="@drawable/sp_white_corner_15"
        android:backgroundTint="@color/green_light_bg"
        android:gravity="center"
        android:paddingStart="@dimen/dp10"
        android:paddingEnd="@dimen/dp10"
        android:text="@string/_offers"
        android:textColor="@color/green_dark"
        android:textSize="@dimen/sp12" />

    <TextView
        android:id="@+id/couponsTv"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp30"
        android:layout_below="@+id/headingTv"
        android:layout_marginStart="@dimen/dp10"
        android:layout_marginTop="@dimen/dp10"
        android:layout_toEndOf="@+id/offerTv"
        android:background="@drawable/sp_white_corner_15"
        android:backgroundTint="@color/red_light"
        android:gravity="center"
        android:paddingStart="@dimen/dp10"
        android:paddingEnd="@dimen/dp10"
        android:text="@string/_coupons"
        android:textColor="@color/red"
        android:textSize="@dimen/sp12" />

    <View
        android:background="@color/grey_light"
        android:layout_marginBottom="@dimen/dp15"
        android:layout_marginTop="@dimen/dp15"
        android:layout_toEndOf="@+id/imageIv"
        android:layout_below="@+id/couponsTv"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp1"/>

</RelativeLayout>